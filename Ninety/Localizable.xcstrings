    "Your sleep data never leaves your device. No servers, no cloud — everything runs locally on your iPhone." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بيانات نومك لا تغادر جهازك أبدًا. لا خوادم ولا سحابة، كل شيء يعمل محليًا على iPhone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos de sueño nunca salen de tu dispositivo. Sin servidores, sin nube: todo se ejecuta localmente en tu iPhone."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi dati sul sonno non lasciano mai il dispositivo. Niente server, niente cloud: tutto gira localmente sul tuo iPhone."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的睡眠数据绝不会离开设备。没有服务器，没有云端，一切都在你的 iPhone 本地运行。"
          }
        }
      }
