    "Tap the clock to choose when you need to be up. Ninety wakes you at the best point in your sleep cycle." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على الساعة لاختيار الوقت الذي تحتاج فيه إلى الاستيقاظ. سيوقظك Ninety في أفضل نقطة من دورة نومك."
          }
        },
        "es" : {
          "stringUnit" : {
